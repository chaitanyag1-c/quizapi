<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Quiz" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
<%= javascript_include_tag 'application' %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      /* Gradient background for navbar */
      .navbar {
        background: linear-gradient(to right,#2662d3, #17b7d1);
        border-radius: 0 0 20px 20px;  /* Rounded corners at the bottom */
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);  /* Soft shadow */
      }

      /* Styling navbar brand */
     


  

      

      .btn-outline-primary:hover {
        background-color: #feb47b;
        color: white;
      }

      .btn-primary:hover {
        background-color: #ff7e5f;
      }

      /* Make sure the navbar doesn't overlap content */
    
    </style>
  </head>

  <body>
    <!-- Navbar -->
<div>
    <nav class="navbar navbar-expand-lg navbar-light fixed-top">
      <div class="container-fluid">
        <%= link_to 'MyQuiz',root_path ,class:"navbar-brand" %>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
          aria-controls="navbarNav"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <% if logged_in? %>
              <li class="nav-item">
                <span class="nav-link active">Welcome, <%= current_user.first_name %></span>
              </li>
              <li class="nav-item">
                <%= link_to "Sign Out", logout_path, method: :delete, class: "btn btn-outline-danger me-2" %>
              </li>
            <% else %>
              <li class="nav-item">
                <%= link_to "Sign In", login_path, class: "btn btn-outline-primary me-2" %>
              </li>
              <li class="nav-item">
                <%= link_to "Sign Up", signup_path, class: "btn btn-primary" %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>
</div>
    <!-- Main Content -->
   <!-- Adjusted margin-top and padding-top for proper spacing -->
      <%= yield %>
   

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-OPmnAnQ8ASkSjz3fVRv+ZWXnCq8nS/2IbiM07ErtS+Lv/VjLs9xKV34N10XA+32r" crossorigin="anonymous"></script>
     <script>
    document.addEventListener("DOMContentLoaded", () => {
      const lookupButton = document.getElementById("lookup_button");
      const quizNameLookup = document.getElementById("quiz_name_lookup");
      const quizNameInput = document.getElementById("quiz_name");

      lookupButton.addEventListener("click", async () => {
        // Fetch distinct quiz names from the server
        const response = await fetch('/quizzes/lookup'); // Adjust the route if needed
        const quizNames = await response.json();

        // Populate the lookup dropdown
        quizNameLookup.innerHTML = '';
        quizNames.forEach(name => {
          const li = document.createElement("li");
          li.className = "list-group-item list-group-item-action";
          li.textContent = name;
          li.addEventListener("click", () => {
            quizNameInput.value = name; // Set the selected name to the input field
            quizNameLookup.style.display = "none"; // Hide the dropdown
          });
          quizNameLookup.appendChild(li);
        });
        quizNameLookup.style.display = "block"; // Show the dropdown
      });
    });
  </script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    <% flash.each do |type, message| %>
      <% alert_type = case type.to_sym %>
        <% when :notice then 'success' %>
        <% when :alert then 'error' %>
        <% else 'info' %>
      <% end %>
      
      Swal.fire({
        icon: '<%= alert_type %>',
        title: '<%= alert_type.capitalize %>',
        text: '<%= j message %>',
        showConfirmButton: false,
        timer: 3000
      });
    <% end %>
  });
</script>

  </body>
</html>
