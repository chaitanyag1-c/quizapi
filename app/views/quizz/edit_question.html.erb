<!DOCTYPE html>
<html>
<head>
  <title>Edit Question</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <!-- Add Bootstrap CSS -->
  <%= stylesheet_link_tag 'https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css', media: 'all' %>
</head>
<body>
  <div class="container mt-5">
    <h1 class="text-center mb-4">Edit Question</h1>

    <%= form_with(model: @question, url: update_question_path(@question), method: :patch, local: true, id: "edit-question-form") do |form| %>
      
      <% if @question.errors.any? %>
        <div class="alert alert-danger">
          <ul>
            <% @question.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <!-- Question Content -->
      <div class="mb-3">
        <%= form.label :content, "Question Text", class: "form-label" %>
        <%= form.text_area :content, class: "form-control", rows: 3, placeholder: "Enter the question text" %>
      </div>

      <!-- Options -->
      <h4>Options</h4>
      <div class="mb-3">
        <%= form.fields_for :options do |option_fields| %>
          <div class="row mb-2">
            <div class="col-md-8">
              <%= option_fields.label :content, "Option Text", class: "form-label" %>
              <%= option_fields.text_field :content, class: "form-control", placeholder: "Enter option text" %>
            </div>
            <div class="col-md-4 d-flex align-items-end">
              <div class="form-check">
                <%= option_fields.label :is_correct_option, "Correct Option?", class: "form-check-label" %>
                <%= option_fields.check_box :is_correct_option, class: "form-check-input correct-option-checkbox" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Submit Button -->
      <div class="d-flex justify-content-between">
        <%= form.submit "Save Changes", class: "btn btn-success" %>
        <%= link_to "Cancel", list_questions_path, class: "btn btn-secondary" %>
      </div>

    <% end %>
  </div>

  <!-- Add Bootstrap JS -->
  <%= javascript_include_tag 'https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js' %>

  <!-- Add JavaScript for Validation -->
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const checkboxes = document.querySelectorAll('.correct-option-checkbox');
      const form = document.getElementById('edit-question-form');

      checkboxes.forEach((checkbox) => {
        checkbox.addEventListener('change', function () {
          if (this.checked) {
            checkboxes.forEach((cb) => {
              if (cb !== this) cb.checked = false;
            });
          }
        });
      });

      form.addEventListener('submit', function (event) {
        const checked = Array.from(checkboxes).some((checkbox) => checkbox.checked);
        if (!checked) {
          event.preventDefault();
          alert('Please select exactly one correct option.');
        }
      });
    });
  </script>
</body>
</html>
