<!DOCTYPE html>
<html>
<head>
  <title>Available Quizzes</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-Gc4WF7x98RA9Sc63+4VvfHrTdSdrb0A/pQghuLgB1jexJ5a1D9gMprTkqg7tPyzH" crossorigin="anonymous">
  <style>
    body {
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      font-family: 'Roboto', sans-serif;
      margin: 0;
      padding: 0;
    }
    .quiz-container {
      background: white;
      border-radius: 15px;
      padding: 40px;
      box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
      max-width: 700px;
      width: 100%;
      text-align: center;
    }
    .quiz-header {
      font-size: 2rem;
      font-weight: bold;
      margin-bottom: 20px;
      color: #007bff;
    }
    .quiz-list {
      list-style-type: none;
      padding: 0;
      margin: 0;
    }
    .quiz-list li {
      margin-bottom: 15px;
    }
    .quiz-list a {
      display: block;
      padding: 15px 20px;
      font-size: 1.2rem;
      font-weight: bold;
      text-align: center;
      background: linear-gradient(90deg, #007bff, #0056b3);
      color: white;
      text-decoration: none;
      border-radius: 8px;
      transition: all 0.3s ease;
    }
    .quiz-list a:hover {
      background: linear-gradient(90deg, #0056b3, #003f80);
      box-shadow: 0 4px 8px rgba(0, 123, 255, 0.3);
    }
    .quiz-footer {
      margin-top: 20px;
      font-size: 0.9rem;
      color: #666;
    }
    .quiz-footer a {
      text-decoration: none;
      color: #007bff;
    }
    .quiz-footer a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="quiz-container">
    <div class="quiz-header">Choose Quiz Category</div>
    <ul class="quiz-list">
      <% @quiz_name.each do |quiz| %>
        <li>
          <%= link_to quiz.name, start_quiz_path(quiz.id), class: "btn" %>
        </li>
      <% end %>
    </ul>
  </div>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-pzjw8f+ua7Kw1TIq5TOeGd+6pD9sqq3VOcoLBUv1E/7oIIobOlFKEf1Qpb7/SkjN" crossorigin="anonymous"></script>
</body>
</html>
