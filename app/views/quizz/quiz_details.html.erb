<!DOCTYPE html>
<html>
<head>
  <title>Quiz Details</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <!-- Add Bootstrap CSS -->
  <%= stylesheet_link_tag 'https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css', media: 'all' %>
</head>
<body>
  <div class="container mt-5">
    <h1 class="text-center mb-4">Quiz Details</h1>

    <table class="table table-striped table-bordered">
      <thead class="table-dark">
        <tr>
          <th>S.NO</th>
          <th>Category</th>
          <th>Question Text</th>
          <th>Option 1</th>
          <th>Option 2</th>
          <th>Option 3</th>
          <th>Option 4</th>
          <th>Correct Option</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% a = 1 %>
        <% @formatted_data.each do |data| %>
          <tr>
            <td><%= a %></td>
            <td><%= data[:category] %></td>
            <td><%= data[:question_text] %></td>
            <td><%= data[:option_1] %></td>
            <td><%= data[:option_2] %></td>
            <td><%= data[:option_3] %></td>
            <td><%= data[:option_4] %></td>
            <td>
              <% correct_option = nil %>
              <% if data[:is_correct_option_1] == true %>
                <% correct_option = data[:option_1] %>
              <% elsif data[:is_correct_option_2] == true %>
                <% correct_option = data[:option_2] %>
              <% elsif data[:is_correct_option_3] == true %>
                <% correct_option = data[:option_3] %>
              <% elsif data[:is_correct_option_4] == true %>
                <% correct_option = data[:option_4] %>
              <% end %>

              <% if correct_option.present? %>
                <span class="badge bg-success"><%= correct_option %></span>
              <% else %>
                <span class="badge bg-danger">None</span>
              <% end %>
            </td>
            <td>
              <%= link_to "Edit", edit_question_path(data[:question_id]), class: "btn btn-primary btn-sm" %>
            </td>
          </tr>
          <% a += 1 %>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Add Bootstrap JS -->
  <%= javascript_include_tag 'https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js' %>
</body>
</html>
