<!DOCTYPE html>
<html>
<head>
  <title>Signup</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <!-- Bootstrap CSS -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    rel="stylesheet"
    integrity="sha384-Gc4WF7x98RA9Sc63+4VvfHrTdSdrb0A/pQghuLgB1jexJ5a1D9gMprTkqg7tPyzH"
    crossorigin="anonymous"
  >
  <style>
    body {
      background: linear-gradient(to bottom right, #e9f7fc, #ffffff);
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      font-family: 'Roboto', sans-serif;
    }
    .signup-container {
      background: white;
      border-radius: 12px;
      padding: 30px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      max-width: 450px;
      width: 100%;
    }
    .logo {
      font-family: 'Poppins', sans-serif;
      font-size: 2rem;
      font-weight: bold;
      color: #007bff;
      text-align: center;
      margin-bottom: 20px;
    }
    .error-messages {
      color: #dc3545;
      font-size: 0.9rem;
      margin-bottom: 20px;
    }
    .btn-primary-custom {
      background-color: #007bff;
      border-color: #007bff;
      color: white;
      font-weight: bold;
      border-radius: 8px;
      transition: background-color 0.3s ease, box-shadow 0.3s ease;
    }
    .btn-primary-custom:hover {
      background-color: #0056b3;
      box-shadow: 0 4px 8px rgba(0, 123, 255, 0.3);
    }
    .auth-links {
      margin-top: 20px;
      text-align: center;
    }
    .auth-links a {
      text-decoration: none;
      font-weight: bold;
      color: #007bff;
    }
    .auth-links a:hover {
      text-decoration: underline;
    }
  </style>
  <script>
  <% if flash[:notice] %>
    toastr.success("<%= flash[:notice] %>");
  <% end %>
</script>
</head>
<body>
  <div class="signup-container">
    <!-- Logo -->
    <div class="logo">MyQuiz</div>

    <!-- Signup Form -->
    <%= form_with model: @user, url: user_post_path, method: 'post', class: 'needs-validation' do |f| %>
      <div class="mb-3">
        <%= f.label :first_name, "First Name", class: "form-label" %>
        <%= f.text_field :first_name, class: "form-control", placeholder: "Enter your first name", required: true %>
      </div>

      <div class="mb-3">
        <%= f.label :last_name, "Last Name", class: "form-label" %>
        <%= f.text_field :last_name, class: "form-control", placeholder: "Enter your last name", required: true %>
      </div>

      <div class="mb-3">
        <%= f.label :username, "Username", class: "form-label" %>
        <%= f.text_field :username, class: "form-control", placeholder: "Enter your Username", required: true %>
      </div>

      <div class="mb-3">
        <%= f.label :email, "Email Address", class: "form-label" %>
        <%= f.email_field :email, class: "form-control", placeholder: "Enter your email", required: true %>
      </div>

      <div class="mb-3">
        <%= f.label :password, "Password", class: "form-label" %>
        <%= f.password_field :password, class: "form-control", placeholder: "Enter your password", required: true %>
      </div>

      <div class="mb-3">
        <%= f.label :password_confirmation, "Confirm Password", class: "form-label" %>
        <%= f.password_field :password_confirmation, class: "form-control", placeholder: "Confirm your password", required: true %>
      </div>

      <div class="mb-3">
      <%= f.label :role, "Role", class: "form-label" %>
      <%= f.select :role, [['Admin', 'Admin'], ['User', 'User']], { prompt: "Select Role" }, class: "form-select", required: true %>
    </div>


      <div class="d-grid gap-2">
        <%= f.submit "Sign Up", class: "btn btn-primary-custom btn-lg" %>
      </div>
    <% end %>

    <!-- Links for Sign In and Sign Up -->
    <div class="auth-links">
            <p>Already have an account? <%= link_to "Sign In", login_path %></p>
      <p>New user? <%= link_to "Sign Up", signup_path %></p>
    </div>
  </div>
</body>


</html>
