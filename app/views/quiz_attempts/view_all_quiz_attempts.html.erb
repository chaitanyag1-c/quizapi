<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tabular Data</title>

  <!-- Bootstrap CSS -->
  <link 
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" 
    rel="stylesheet" 
    integrity="sha384-Gc4WF7x98RA9Sc63+4VvfHrTdSdrb0A/pQghuLgB1jexJ5a1D9gMprTkqg7tPyzH" 
    crossorigin="anonymous">
  
  <style>
    body {
      background: linear-gradient(to bottom right, #e9f7fc, #ffffff);
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      font-family: 'Roboto', sans-serif;
      padding: 20px;
    }
    .table-container {
      background: white;
      border-radius: 12px;
      padding: 20px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      max-width: 1200px;
      width: 100%;
    }
    .table-header {
      font-size: 1.5rem;
      font-weight: bold;
      color: #007bff;
      text-align: center;
      margin-bottom: 20px;
    }
    .table th {
      background-color: #007bff;
      color: white;
      text-align: center;
    }
    .table td {
      text-align: center;
    }
    .score-high {
      font-weight: bold;
      color: #28a745; /* Green for high score */
    }
    .score-low {
      font-weight: bold;
      color: #dc3545; /* Red for low score */
    }
  </style>
</head>
<body>

  <div class="table-container">
    <div class="table-header">Hi <%= current_user.first_name %>, Here are your Quiz Attempts</div>
    <table class="table table-striped table-bordered">
      <thead>
        <tr>
          <th>ID</th>
          <th>User</th>
          <th>Quiz Category</th>
          <th>Score</th>
          <th>Started At</th>
          <th>Completed At</th>
          <th>View Detail</th>
        </tr>
      </thead>
      <tbody>
        <% @quiz_attempts.each do |attempt| %>
          <tr>
            <td><%= attempt.id %></td>
            <td><%= attempt.user.first_name %></td>
            <td><%= attempt.quizz.name %></td>
            <td>
              <% if attempt.score.present? && attempt.score > 3 %>
                <span class="score-high"><%= attempt.score %></span>
              <% elsif attempt.score.present? %>
                <span class="score-low"><%= attempt.score %></span>
              <% else %>
                N/A
              <% end %>
            </td>
            <td><%= attempt.created_at || "N/A" %></td>
            <td><%= attempt.completed_at || "N/A" %></td>
            <td><%= link_to "View Result", show_quiz_result_path(attempt), class: "btn btn-primary" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <%= link_to "Back to Home Page", root_path, class: "btn btn-primary" %>
  </div>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
