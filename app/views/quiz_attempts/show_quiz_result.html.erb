<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quiz Results</title>
  
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-Gc4WF7x98RA9Sc63+4VvfHrTdSdrb0A/pQghuLgB1jexJ5a1D9gMprTkqg7tPyzH" crossorigin="anonymous">
  
  <!-- Custom styles -->
  <style>
    body {
      background: linear-gradient(to bottom right, #e9f7fc, #ffffff);
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      font-family: 'Roboto', sans-serif;
      padding: 20px;
    }
    .result-container {
      background: white;
      border-radius: 12px;
      padding: 30px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      max-width: 100%;
      width: 100%;
    }
    .result-header {
      font-family: 'Poppins', sans-serif;
      font-size: 2rem;
      font-weight: bold;
      color: #007bff;
      text-align: center;
      margin-bottom: 20px;
    }
    .result-table th {
      background-color: #007bff;
      color: white;
    }
    .badge {
      font-size: 0.9rem;
    }
    .score {
      font-size: 1.25rem;
      font-weight: bold;
      color: #28a745;
      text-align: center;
    }
    .quiz-meta {
      font-size: 1rem;
      font-weight: normal;
      color: #6c757d;
      text-align: center;
      margin-bottom: 20px;
    }
    .btn-container {
      display: flex;
      justify-content: center;
      gap: 10px;
      margin-top: 20px;
    }
  </style>
</head>
<body>

  <div class="result-container">
    <div class="result-header">Your Quiz Results</div>
    
    <!-- Quiz Taken On -->
    <div class="quiz-meta">
      <p>Quiz taken on: <%= @formatted_data.first[:completed_at].strftime('%B %d, %Y at %I:%M %p') %></p>
    </div>
    
    <!-- Responsive Table -->
    <div class="table-responsive">
      <table class="table table-striped">
        <thead>
          <tr>
            <th>Question</th>
            <th>Correct Answer</th>
            <th>Your Answer</th>
            <th>Score</th>
          </tr>
        </thead>
        <tbody>
          <% @formatted_data.each do |data| %>
            <tr>
              <td><%= data[:question] %></td>
              <td>
                <span class="badge bg-success"><%= data[:correct_option] %></span>
              </td>
              <td>
                <span class="<%= data[:selected_option] == data[:correct_option] ? 'badge bg-success' : 'badge bg-danger' %>">
                  <%= data[:selected_option] %>
                </span>
              </td>
              <td><%= data[:score] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <%= link_to "Back", view_all_quiz_attempts_path, class: "btn btn-primary" %>
    </div>
